# claude-buffer-sns 환경 변수 — .env.example
# 사용법: cp .env.example .env  후 실제 값 입력
# ⚠️  .env 파일은 절대 git에 커밋하지 마세요. .gitignore에 등록되어 있습니다.

# Buffer API 키 — https://publish.buffer.com/settings/api 에서 발급
BUFFER_API_KEY=your_buffer_api_key_here

# (선택) 발행 승인자 식별자 — publish-gate.sh의 --approved-by 기본값
PUBLISH_APPROVER=your_name_here

# (선택) 기본 타임존 — 스케줄 시간 해석 기준 (Buffer 계정 timezone 우선)
DEFAULT_TIMEZONE=Asia/Seoul
